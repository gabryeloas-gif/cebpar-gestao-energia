{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cebpar-gestao-energia",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-13",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [{
    "binding": "DB",
    "database_name": "cebpar-db",
    "database_id": "SUBSTITUIR_APOS_CRIAR_O_BANCO",
    "migrations_dir": "migrations"
  }]
}
